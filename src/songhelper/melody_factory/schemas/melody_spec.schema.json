{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MelodySpec",
  "type": "object",
  "required": ["id", "title", "key", "meter", "tempo", "bars"],
  "properties": {
    "id": {"type": "string"},
    "title": {"type": "string"},
    "key": {"type": "string"},
    "meter": {"type": "string", "enum": ["4/4", "3/4", "6/8"]},
    "tempo": {"type": "number", "exclusiveMinimum": 0},
    "bars": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["degrees", "rhythm"],
        "properties": {
          "degrees": {"type": "string"},
          "rhythm": {"type": "string"},
          "lyrics": {"type": "string"},
          "annotations": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "highest_word": {"type": ["string", "null"]},
    "cadence": {"type": ["string", "null"]},
    "contour": {"type": ["string", "null"]},
    "range_limit": {"type": ["string", "null"]},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "confidence_note": {"type": ["string", "null"]}
  },
  "additionalProperties": false
}
